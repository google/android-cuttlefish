---
 rust/daemon/src/args.rs | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/rust/daemon/src/args.rs b/rust/daemon/src/args.rs
index d24442f3..5e20bd44 100644
--- a/rust/daemon/src/args.rs
+++ b/rust/daemon/src/args.rs
@@ -65,7 +65,7 @@ pub struct NetsimdArgs {
     pub forward_host_mdns: bool,
 
     /// Set the vsock port number to be listened by the frontend grpc server
