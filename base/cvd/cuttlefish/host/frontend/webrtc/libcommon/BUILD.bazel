cf_cc_library(
    name = "utils",
    srcs = ["utils.cpp"],
    hdrs = ["utils.h"],
    deps = [
        "//cuttlefish/common/libs/utils:json",
        "//cuttlefish/result",
        "//libbase",
        "@abseil-cpp//absl/log",
        "@fmt",
        "@jsoncpp",
        "@libwebrtc",
    ],
)

cf_cc_library(
    name = "vp8only_encoder_factory",
    srcs = ["vp8only_encoder_factory.cpp"],
    hdrs = ["vp8only_encoder_factory.h"],
    deps = [
        "@libwebrtc",
    ],
)
